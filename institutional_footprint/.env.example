# Institutional Footprint - Configuration
# ========================================
# Copy to .env and fill in your values

# Bridge Configuration
BRIDGE_PORT=3000
PYTHON_ENGINE_URL=http://localhost:8080
WEBHOOK_SECRET=your_secret_here_generate_with_openssl_rand_hex_32

# Risk Management
RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
MAX_DAILY_TRADES=3
MAX_SLIPPAGE_PIPS=2.0

# CVD Validation
CVD_LOOKBACK=10
CVD_THRESHOLD=0.3
MIN_ABSORPTION_VOLUME=50

# Execution
USE_LIMIT_ORDERS=true
LIMIT_OFFSET_PIPS=0.5
MARKET_TIMEOUT_MS=500

# Logging
LOG_FILE=/opt/trading-bridge/data/execution_log.csv
STATE_FILE=/opt/trading-bridge/data/engine_state.json

# TradingView Alert URL (configure in TradingView)
# http://YOUR_VPS_IP:3000/webhook?secret=YOUR_SECRET_HERE
