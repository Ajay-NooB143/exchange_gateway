# ══════════════════════════════════════════════════════════════════════════════
# EXECUTION-READY WEBHOOK BRIDGE — Environment Configuration
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# Server
PORT=3000

# Webhook Security — must match your TradingView alert URL secret parameter
# e.g. https://your-server.com/webhook?secret=YOUR_SECRET_HERE
WEBHOOK_SECRET=change-me-to-a-strong-random-string

# Broker API (replace with your broker's credentials)
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_BASE_URL=https://api.broker.com/v1

# Safety Limits
MAX_POSITION_SIZE=10
MAX_DAILY_TRADES=20
ALLOWED_SYMBOLS=XAUUSD

# Logging: info, warn, error, debug
LOG_LEVEL=info
