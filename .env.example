# OMNI BRAIN V2 - Environment Variables
# =====================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ══════════════════════════════════════════════════════════════════════════════
# MT5 BROKER CONNECTION
# ══════════════════════════════════════════════════════════════════════════════

MT5_LOGIN=your_mt5_login
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_mt5_server

# ══════════════════════════════════════════════════════════════════════════════
# TELEGRAM ALERTS
# ══════════════════════════════════════════════════════════════════════════════

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ══════════════════════════════════════════════════════════════════════════════
# TWELVE DATA LIVE FEED
# ══════════════════════════════════════════════════════════════════════════════

# Get from https://twelvedata.com/account → API Keys
LIVE_DATA_API_KEY=your_twelve_data_api_key

# Provider name (auto-detected)
LIVE_DATA_PROVIDER=twelve_data

# Scan interval in seconds (default: 60)
SCAN_INTERVAL_SECONDS=60

# Mock data mode (for testing without live API)
# Set to true to bypass live API and use synthetic data
USE_MOCK_DATA=false

# Override score value when using mock data (0 = use normal scoring)
MOCK_SCORE_OVERRIDE=0

# ══════════════════════════════════════════════════════════════════════════════
# GITHUB SIGNAL ARCHIVE
# ══════════════════════════════════════════════════════════════════════════════

# GitHub Personal Access Token (Settings → Developer settings → Personal access tokens)
GITHUB_TOKEN=your_github_pat_token

# GitHub repository for signal archive (format: username/repo)
GITHUB_REPO=yourusername/signals-log

# ══════════════════════════════════════════════════════════════════════════════
# TRADING PARAMETERS
# ══════════════════════════════════════════════════════════════════════════════

MAX_POSITION_SIZE=0.1
MAX_DAILY_TRADES=20
MAX_DRAWDOWN_PCT=3
RISK_PER_TRADE_PCT=1

# ══════════════════════════════════════════════════════════════════════════════
# RISK MANAGER (new)
# ══════════════════════════════════════════════════════════════════════════════

ACCOUNT_BALANCE=10000
RISK_PCT=1.0
MAX_DAILY_LOSS_PCT=3
MAX_TRADES_PER_PAIR=6
MAX_CONCURRENT_TRADES=2
DRAWDOWN_LIMIT_PCT=10
SPREAD_MAX_PIPS=3.0

# ══════════════════════════════════════════════════════════════════════════════
# NEWS BLOCKING (new)
# ══════════════════════════════════════════════════════════════════════════════

NEWS_BLOCK_MINUTES=30

# ══════════════════════════════════════════════════════════════════════════════
# TELEGRAM QUIET HOURS (new)
# ══════════════════════════════════════════════════════════════════════════════
# Set to 0/0 to disable quiet hours entirely
TELEGRAM_QUIET_START=0
TELEGRAM_QUIET_END=0

# ══════════════════════════════════════════════════════════════════════════════
# MCP STACK (optional)
# ══════════════════════════════════════════════════════════════════════════════

PERPLEXITY_API_KEY=pplx-your_perplexity_key
FIRECRAWL_API_KEY=your_firecrawl_key

# ══════════════════════════════════════════════════════════════════════════════
# LEGACY TRADING PARAMS (kept for backward compatibility)
# ══════════════════════════════════════════════════════════════════════════════

MAX_POSITION_SIZE=0.1
MAX_DAILY_TRADES=20
MAX_DRAWDOWN_PCT=3
RISK_PER_TRADE_PCT=1

# ══════════════════════════════════════════════════════════════════════════════
# PAPER TRADING (new)
# ══════════════════════════════════════════════════════════════════════════════

PAPER_BALANCE=10000
PAPER_MONITOR_INTERVAL=900

# ══════════════════════════════════════════════════════════════════════════════
# MONETIZATION (new)
# ══════════════════════════════════════════════════════════════════════════════

VIP_MONTHLY_PRICE=29
VIP_PRICE_3MONTH=69
VIP_PRICE_YEARLY=199
ADMIN_CHAT_ID=your_admin_telegram_chat_id
PAYMENT_LINK=https://your-payment-link

# ══════════════════════════════════════════════════════════════════════════════
# NETWORK
# ══════════════════════════════════════════════════════════════════════════════

PORT=3000
BIND_HOST=0.0.0.0

# VPS Configuration
VPS_IP=172.105.252.194
VPS_PATH=/opt/trading-bridge

# ══════════════════════════════════════════════════════════════════════════════
# EXCHANGE GATEWAY (ccxt — Binance/Bybit)
# ══════════════════════════════════════════════════════════════════════════════

# Paper mode: true = simulated orders, false = live trading
PAPER_MODE=true

# Binance (optional — leave empty to skip)
EXCHANGE_GATEWAY_BINANCE_API_KEY=
EXCHANGE_GATEWAY_BINANCE_API_SECRET=
EXCHANGE_GATEWAY_BINANCE_TESTNET=true

# Bybit (optional — leave empty to skip)
EXCHANGE_GATEWAY_BYBIT_API_KEY=
EXCHANGE_GATEWAY_BYBIT_API_SECRET=
EXCHANGE_GATEWAY_BYBIT_TESTNET=true

# ══════════════════════════════════════════════════════════════════════════════
# WEBSOCKET SCANNER (real-time price feeds)
# ══════════════════════════════════════════════════════════════════════════════

# Exchange for WS feeds (binance or bybit)
WS_EXCHANGE=binance

# Symbols to subscribe (comma-separated)
WS_SYMBOLS=BTCUSD,ETHUSD,XAUUSD
