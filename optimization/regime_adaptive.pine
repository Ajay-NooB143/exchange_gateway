// ══════════════════════════════════════════════════════════════════════════════
// REGIME-ADAPTIVE POSITION SIZING — Pine Script v6
// Reduces position size by 50% in trending regime on 15m ATR percentile
// ══════════════════════════════════════════════════════════════════════════════
//@version=6
strategy("Institutional Sniper — Regime Adaptive", 
     overlay                = true,
     default_qty_type       = strategy.fixed,
     default_qty_value      = 0,
     initial_capital        = 10000,
     commission_type        = strategy.commission.percent,
     commission_value       = 0.02,
     slippage               = 2,
     calc_on_every_tick     = false,
     process_orders_on_close = false,
     pyramiding             = 0)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

// --- Regime Filter ---
RegimeTimeframe  = input.timeframe("15", "Regime Timeframe",       group="Regime")
RegimeLookback   = input.int(100,        "Regime Percentile Lookback", group="Regime")
TrendReduction   = input.float(0.5,      "Position Reduction in Trend", step=0.1, group="Regime", tooltip="0.5 = 50% smaller in trending")
RangingBoost     = input.float(1.0,      "Position Multiplier in Range", step=0.1, group="Regime", tooltip="1.0 = full size in ranging")
TransitionScale  = input.float(0.75,     "Position Multiplier in Transition", step=0.05, group="Regime")
VolRegimeFilter  = input.bool(true,      "Use Volume-Regime Confirmation", group="Regime")

// --- Risk ---
RiskPct      = input.float(1.0, "Risk % per Trade",    step=0.1,  group="Risk")
AtrSlMult    = input.float(1.5, "SL ATR Multiple",     step=0.1,  group="Risk")
AtrLen       = input.int(14,    "ATR Period",           group="Risk")
SweepLookback = input.int(10,   "Sweep Lookback",      group="Structure")

// --- Session ---
SessionStart = input.int(13, "Session Start (GMT)",  group="Session")
SessionEnd   = input.int(16, "Session End (GMT)",    group="Session")
GmtOffset    = input.int(0,  "GMT Offset",          group="Session")

// ══════════════════════════════════════════════════════════════════════════════
// MODULE: REGIME DETECTION (15-minute ATR Percentile)
// ══════════════════════════════════════════════════════════════════════════════

// Fetch 15m ATR on current chart — barmerge.lookahead_off prevents future leakage
float htfAtr = request.security(syminfo.tickerid, RegimeTimeframe, ta.atr(AtrLen), barmerge.gaps_off, barmerge.lookahead_off)

// Calculate percentile on 15m data
float htfAtrPctile = 0.0
for i = 0 to RegimeLookback - 1
    float htfAtrPrev = request.security(syminfo.tickerid, RegimeTimeframe, ta.atr(AtrLen)[i], barmerge.gaps_off, barmerge.lookahead_off)
    if not na(htfAtrPrev) and not na(htfAtr)
        if htfAtr > htfAtrPrev
            htfAtrPctile += 1.0
htfAtrPctile := htfAtrPctile / RegimeLookback

// Regime classification
string regime = htfAtrPctile > 0.7 ? "TRENDING" : htfAtrPctile < 0.3 ? "RANGING" : "TRANSITIONING"

// --- Volume-Regime Confirmation ---
// In trending markets, volume should be expanding
float volSma20   = ta.sma(volume, 20)
float volSma50   = ta.sma(volume, 50)
bool  volExpand  = volSma20 > volSma50
bool  volConfirm = VolRegimeFilter ? (regime == "TRENDING" ? volExpand : true) : true

// ══════════════════════════════════════════════════════════════════════════════
// MODULE: REGIME-ADAPTIVE POSITION SIZING
// ══════════════════════════════════════════════════════════════════════════════

float regimeMultiplier = regime == "TRENDING" ? TrendReduction : regime == "RANGING" ? RangingBoost : TransitionScale

float currentAtr = ta.atr(AtrLen)
float stopDist   = currentAtr * AtrSlMult

f_calcQty(float eq, float riskFrac, float sl, float px, float regimeMult) =>
    float riskAmt  = eq * riskFrac
    float rawUnits = math.floor(riskAmt / sl)
    float maxAlloc = math.floor((eq * 0.20) / px)
    float adjusted = math.floor(rawUnits * regimeMult)
    int   qty      = int(math.min(adjusted, maxAlloc))
    qty >= 1 ? qty : 0

// ══════════════════════════════════════════════════════════════════════════════
// MODULE: MARKET STRUCTURE (Simplified)
// ══════════════════════════════════════════════════════════════════════════════

float recentHigh = ta.highest(high[1], SweepLookback)
float recentLow  = ta.lowest(low[1],   SweepLookback)

bool sweepHigh = high > recentHigh and close < recentHigh
bool sweepLow  = low  < recentLow  and close > recentLow

float swH = ta.pivothigh(high, 5, 5)
float swL = ta.pivotlow(low, 5, 5)
var float lastSwH = na
var float lastSwL = na
if not na(swH)
    lastSwH := swH
if not na(swL)
    lastSwL := swL

bool mssBull = sweepLow  and not na(lastSwH) and close > lastSwH
bool mssBear = sweepHigh and not na(lastSwL) and close < lastSwL

bool fvgBull = low > high[2]
bool fvgBear = high < low[2]

bool structLong  = mssBull and fvgBull
bool structShort = mssBear and fvgBear

// ══════════════════════════════════════════════════════════════════════════════
// MODULE: VOLUME FILTER
// ══════════════════════════════════════════════════════════════════════════════

float volSma   = ta.sma(volume, 20)
bool volumeOK  = volume >= volSma * 1.5
float rawRsi   = ta.rsi(close, 14)
float volRatio = volSma > 0 ? volume / volSma : 0
float vwrsi    = rawRsi * math.min(volRatio, 3.0) / 3.0

bool volLong  = vwrsi < 30 and volumeOK
bool volShort = vwrsi > 70 and volumeOK

// ══════════════════════════════════════════════════════════════════════════════
// MODULE: SESSION + PRE-FLIGHT
// ══════════════════════════════════════════════════════════════════════════════

int   gmtHour   = hour(time, "GMT" + str.tostring(GmtOffset))
bool  inSession = gmtHour >= SessionStart and gmtHour < SessionEnd
bool  confirmed = barstate.isconfirmed
bool  validAtr  = not na(currentAtr) and currentAtr > 0
bool  systemOK  = validAtr and confirmed

// ══════════════════════════════════════════════════════════════════════════════
// ENTRIES
// ══════════════════════════════════════════════════════════════════════════════

int qty = 0
if systemOK
    qty := f_calcQty(strategy.equity, RiskPct / 100.0, stopDist, close, regimeMultiplier)

bool entryLong  = structLong  and volLong  and inSession and systemOK and volConfirm and qty > 0
bool entryShort = structShort and volShort and inSession and systemOK and volConfirm and qty > 0

var float entryPx     = na
var float activeSL    = na
var bool  beTriggered = false

if entryLong and strategy.position_size == 0
    entryPx     := close
    activeSL    := close - stopDist
    beTriggered := false
    strategy.entry("LONG", strategy.long, qty=qty, 
         comment="REGIME:" + regime + " x" + str.tostring(regimeMultiplier, "#.#"))

if entryShort and strategy.position_size == 0
    entryPx     := close
    activeSL    := close + stopDist
    beTriggered := false
    strategy.entry("SHORT", strategy.short, qty=qty,
         comment="REGIME:" + regime + " x" + str.tostring(regimeMultiplier, "#.#"))

// Break-even
if strategy.position_size > 0 and not na(entryPx)
    float reward = close - entryPx
    float risk   = entryPx - activeSL
    if not beTriggered and reward >= risk and risk > 0
        activeSL    := entryPx + (currentAtr * 0.1)
        beTriggered := true
    strategy.exit("L EXIT", "LONG", stop=activeSL)

if strategy.position_size < 0 and not na(entryPx)
    float reward = entryPx - close
    float risk   = activeSL - entryPx
    if not beTriggered and reward >= risk and risk > 0
        activeSL    := entryPx - (currentAtr * 0.1)
        beTriggered := true
    strategy.exit("S EXIT", "SHORT", stop=activeSL)

if strategy.position_size == 0
    entryPx     := na
    activeSL    := na
    beTriggered := false

// ══════════════════════════════════════════════════════════════════════════════
// DASHBOARD
// ══════════════════════════════════════════════════════════════════════════════

bgcolor(inSession ? color.new(color.blue, 93) : na)

color regimeBg = regime == "TRENDING" ? color.new(color.lime, 95) : regime == "RANGING" ? color.new(color.orange, 95) : color.new(color.gray, 95)
bgcolor(regimeBg, title="Regime Background")

var table dash = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 15), border_width=1)
if barstate.islastconfirmedhistory
    color rc = regime == "TRENDING" ? color.lime : regime == "RANGING" ? color.orange : color.gray
    table.cell(dash, 0, 0, "REGIME ENGINE", text_color=color.white, text_size=size.tiny)
    table.merge_cells(dash, 0, 0, 1, 0)
    table.cell(dash, 0, 1, "REGIME", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 1, regime, text_color=rc, text_size=size.tiny)
    table.cell(dash, 0, 2, "15M ATR %ile", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 2, str.tostring(htfAtrPctile * 100, "#.#") + "%", text_color=rc, text_size=size.tiny)
    table.cell(dash, 0, 3, "POSITION MULT", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(regimeMultiplier, "#.#") + "x", text_color=rc, text_size=size.tiny)
    table.cell(dash, 0, 4, "QTY (ADJUSTED)", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 4, str.tostring(qty), text_color=color.lime, text_size=size.tiny)
    table.cell(dash, 0, 5, "VOL CONFIRM", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 5, volConfirm ? "YES" : "NO", text_color=volConfirm ? color.lime : color.red, text_size=size.tiny)
