// ══════════════════════════════════════════════════════════════════════════════
// MODULE 1 — VOLUME-WEIGHTED ORDER FLOW ANALYSIS
// ══════════════════════════════════════════════════════════════════════════════
//@version=6
indicator("Order Flow Analysis", overlay=false)

// Buy/Sell volume estimation using candle position
float candleRange = high - low
float buyRatio    = candleRange > 0 ? (close - low) / candleRange : 0.5
float sellRatio   = candleRange > 0 ? (high - close) / candleRange : 0.5

float buyVolume  = volume * buyRatio
float sellVolume = volume * sellRatio
float delta      = buyVolume - sellVolume

// Cumulative Delta Volume (resets at session start)
var float cvd = 0.0
if na(cvd[1]) or hour != hour[1]
    cvd := delta
else
    cvd := cvd + delta

// Divergence detection
int lookback = 20
float priceHigh  = ta.highest(close, lookback)
float cvdHigh    = ta.highest(cvd, lookback)
float priceLow   = ta.lowest(close, lookback)
float cvdLow     = ta.lowest(cvd, lookback)

bool bearDiv = close >= priceHigh and cvd < cvdHigh  // price new high, CVD not
bool bullDiv = close <= priceLow  and cvd > cvdLow   // price new low, CVD not

// Plot
plot(cvd, "CVD", color=cvd > cvd[1] ? color.lime : color.red, linewidth=2)
hline(0, "Zero", color=color.gray, linestyle=hline.style_dotted)
plotshape(bearDiv, "Bearish Div", shape.triangledown, location.top, color.red, size=size.tiny)
plotshape(bullDiv, "Bullish Div", shape.triangleup, location.bottom, color.lime, size=size.tiny)


// ══════════════════════════════════════════════════════════════════════════════
// MODULE 2 — REGIME-AWARE ADAPTIVE INDICATORS
// ══════════════════════════════════════════════════════════════════════════════
//@version=6
indicator("Adaptive Regime Engine", overlay=true)

// --- Regime Detection via ATR Percentile ---
int   atrLen     = input.int(14, "ATR Period")
int   pctileLen  = input.int(100, "Percentile Lookback")

float atr = ta.atr(atrLen)
float atrRank = 0.0
for i = 0 to pctileLen - 1
    if atr > atr[i]
        atrRank += 1.0
float atrPctile = atrRank / pctileLen

string regime = atrPctile > 0.7 ? "TRENDING" : atrPctile < 0.3 ? "RANGING" : "TRANSITIONING"
color  regimeColor = atrPctile > 0.7 ? color.lime : atrPctile < 0.3 ? color.orange : color.gray

// --- Adaptive Bollinger Bands ---
float bbMult = atrPctile > 0.7 ? 2.5 : atrPctile < 0.3 ? 1.5 : 2.0
int   bbLen  = atrPctile > 0.7 ? 20 : atrPctile < 0.3 ? 15 : 20

float bbBasis = ta.sma(close, bbLen)
float bbDev   = ta.stdev(close, bbLen) * bbMult
float bbUpper = bbBasis + bbDev
float bbLower = bbBasis - bbDev

plot(bbUpper, "Upper", color=color.new(color.red, 40))
plot(bbLower, "Lower", color=color.new(color.lime, 40))
plot(bbBasis, "Basis", color=color.gray)

// --- Adaptive RSI ---
int rsiLen = atrPctile > 0.7 ? 21 : atrPctile < 0.3 ? 7 : 14
float adaptiveRsi = ta.rsi(close, rsiLen)

// Regime label
var table regimeTable = table.new(position.bottom_right, 2, 2, bgcolor=color.new(color.black, 20), border_width=1)
if barstate.islastconfirmedhistory
    table.cell(regimeTable, 0, 0, "REGIME", text_color=color.gray, text_size=size.tiny)
    table.cell(regimeTable, 1, 0, regime, text_color=regimeColor, text_size=size.tiny)
    table.cell(regimeTable, 0, 1, "ATR %ile", text_color=color.gray, text_size=size.tiny)
    table.cell(regimeTable, 1, 1, str.tostring(atrPctile * 100, "#.#") + "%", text_color=regimeColor, text_size=size.tiny)


// ══════════════════════════════════════════════════════════════════════════════
// MODULE 3 — DYNAMIC NEWS-FILTERING LOGIC
// ══════════════════════════════════════════════════════════════════════════════
//@version=6
indicator("News Filter", overlay=false)

// --- Method A: Volatility Spike Detection ---
int   volSpikeLen  = input.int(50, "Volume Baseline Period")
int   atrShort     = input.int(5,  "Short ATR Period")
int   atrLong      = input.int(50, "Long ATR Period")
float volThreshold = input.float(3.0, "Volume Spike Threshold", step=0.5)
float atrThreshold = input.float(2.5, "ATR Spike Threshold", step=0.5)
int   pauseBars    = input.int(15, "Pause Duration (bars after spike)")

float volSma     = ta.sma(volume, volSpikeLen)
float volSpike   = volSma > 0 ? volume / volSma : 0
float atrShortV  = ta.atr(atrShort)
float atrLongV   = ta.atr(atrLong)
float atrSpike   = atrLongV > 0 ? atrShortV / atrLongV : 0

bool volAnomaly  = volSpike > volThreshold
bool atrAnomaly  = atrSpike > atrThreshold
bool newsEvent   = volAnomaly or atrAnomaly

// Pause timer after detected event
var int pauseCounter = 0
if newsEvent
    pauseCounter := pauseBars
else if pauseCounter > 0
    pauseCounter -= 1

bool filterActive = pauseCounter > 0 or newsEvent

// --- Method B: Price Velocity ---
int   velLookback = input.int(5, "Velocity Lookback")
float priceMove   = math.abs(close - close[velLookback])
float normalMove  = atr * math.sqrt(velLookback)
float velocity    = normalMove > 0 ? priceMove / normalMove : 0
bool  extremeMove = velocity > 4.0

// Plot
plot(volSpike, "Vol Spike", color=volAnomaly ? color.red : color.gray)
hline(volThreshold, "Threshold", color=color.red, linestyle=hline.style_dashed)
plot(atrSpike, "ATR Spike", color=atrAnomaly ? color.orange : color.gray, display=display.pane)
hline(atrThreshold, "ATR Threshold", color=color.orange, linestyle=hline.style_dashed)
bgcolor(filterActive ? color.new(color.red, 90) : na, title="News Pause")


// ══════════════════════════════════════════════════════════════════════════════
// MODULE 4 — MTF CONFLUENCE ALIGNMENT
// ══════════════════════════════════════════════════════════════════════════════
//@version=6
indicator("MTF Confluence", overlay=true)

// --- HTF: Direction (1H or 4H) ---
string htf = input.timeframe("60", "Higher Timeframe")
float htfEma200 = request.security(syminfo.tickerid, htf, ta.ema(close, 200), barmerge.gaps_off, barmerge.lookahead_off)
float htfClose  = request.security(syminfo.tickerid, htf, close, barmerge.gaps_off, barmerge.lookahead_off)

// Structure detection via swing points
float htfSwingH = request.security(syminfo.tickerid, htf, ta.pivothigh(high, 5, 5), barmerge.gaps_off, barmerge.lookahead_off)
float htfSwingL = request.security(syminfo.tickerid, htf, ta.pivotlow(low, 5, 5), barmerge.gaps_off, barmerge.lookahead_off)

var float lastHtfSwingH = na
var float lastHtfSwingL = na
if not na(htfSwingH)
    lastHtfSwingH := htfSwingH
if not na(htfSwingL)
    lastHtfSwingL := htfSwingL

bool htfBullStructure = not na(lastHtfSwingH) and htfClose > lastHtfSwingH
bool htfBearStructure = not na(lastHtfSwingL) and htfClose < lastHtfSwingL

bool htfBull = htfClose > htfEma200 and htfBullStructure
bool htfBear = htfClose < htfEma200 and htfBearStructure

// --- MTF: Momentum (15M) ---
string mtf = input.timeframe("15", "Middle Timeframe")
float mtfRsi      = request.security(syminfo.tickerid, mtf, ta.rsi(close, 14), barmerge.gaps_off, barmerge.lookahead_off)
float mtfMacdHist = request.security(syminfo.tickerid, mtf, ta.macd(close, 12, 26, 9) - ta.sma(ta.macd(close, 12, 26, 9), 9), barmerge.gaps_off, barmerge.lookahead_off)

bool mtfBull = mtfRsi > 50 and mtfMacdHist > 0
bool mtfBear = mtfRsi < 50 and mtfMacdHist < 0

// --- LTF: Entry Trigger (current chart) ---
// Uses the same sweep+FVG logic from the institutional strategy
int sweepLen = 10
float recentH = ta.highest(high[1], sweepLen)
float recentL = ta.lowest(low[1], sweepLen)
bool sweepH   = high > recentH and close < recentH
bool sweepL   = low  < recentL and close > recentL

float swH = ta.pivothigh(high, 5, 5)
float swL = ta.pivotlow(low, 5, 5)
var float lastSwH = na
var float lastSwL = na
if not na(swH)
    lastSwH := swH
if not na(swL)
    lastSwL := swL

bool mssBull = sweepL and not na(lastSwH) and close > lastSwH
bool mssBear = sweepH and not na(lastSwL) and close < lastSwL

float fvgBull = low > high[2]
float fvgBear = high < low[2]

bool ltfLong  = mssBull and fvgBull > 0
bool ltfShort = mssBear and fvgBear > 0

// --- CONFLUENCE GATE ---
bool fullAlignLong  = htfBull  and mtfBull  and ltfLong
bool fullAlignShort = htfBear  and mtfBear  and ltfShort

// --- Visual ---
plotshape(fullAlignLong  and strategy.position_size == 0, "MTF Long",  shape.labelup,   location.belowbar, color.lime, text="MTF L", textcolor=color.white, size=size.small)
plotshape(fullAlignShort and strategy.position_size == 0, "MTF Short", shape.labeldown, location.abovebar, color.red,  text="MTF S", textcolor=color.white, size=size.small)

// Dashboard
var table mtfDash = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 15), border_width=1)
if barstate.islastconfirmedhistory
    table.cell(mtfDash, 0, 0, "MTF ALIGNMENT", text_color=color.white, text_size=size.tiny)
    table.merge_cells(mtfDash, 0, 0, 1, 0)
    table.cell(mtfDash, 0, 1, "HTF", text_color=color.gray, text_size=size.tiny)
    table.cell(mtfDash, 1, 1, htfBull ? "BULL" : htfBear ? "BEAR" : "NEUTRAL", text_color=htfBull ? color.lime : htfBear ? color.red : color.gray, text_size=size.tiny)
    table.cell(mtfDash, 0, 2, "MTF", text_color=color.gray, text_size=size.tiny)
    table.cell(mtfDash, 1, 2, mtfBull ? "BULL" : mtfBear ? "BEAR" : "NEUTRAL", text_color=mtfBull ? color.lime : mtfBear ? color.red : color.gray, text_size=size.tiny)
    table.cell(mtfDash, 0, 3, "LTF", text_color=color.gray, text_size=size.tiny)
    table.cell(mtfDash, 1, 3, ltfLong ? "LONG" : ltfShort ? "SHORT" : "WAITING", text_color=ltfLong ? color.lime : ltfShort ? color.red : color.gray, text_size=size.tiny)
